<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.Extras"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Demo00.GroupGrid.MainWindow"
        Width="1100"
        Height="720"
        Title="Demo00.GroupGrid">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    Margin="8"
                    Spacing="8">
            <ComboBox x:Name="SourceComboBox"
                      Width="180"
                      SelectionChanged="SourceComboBox_SelectionChanged">
                <ComboBoxItem>POCO List</ComboBoxItem>
                <ComboBoxItem>DataTable</ComboBoxItem>
                <ComboBoxItem>DataView</ComboBoxItem>
            </ComboBox>
            <Button Content="Clear"
                    Click="ClearButton_Click" />
        </StackPanel>
        <controls:GroupGrid x:Name="Grid" />
    </DockPanel>
</Window>
